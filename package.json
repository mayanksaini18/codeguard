{
  "name": "codeguard",
  "version": "0.1.0",
  "description": "A git-native PR review agent built on the GitAgent standard",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codeguard": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx runtime/index.ts",
    "review": "tsx runtime/index.ts review"
  },
  "keywords": [
    "gitagent",
    "code-review",
    "ai",
    "claude",
    "github",
    "pr-review"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@octokit/rest": "^21.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
